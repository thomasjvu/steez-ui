{
  "name": "@steez-ui/ui",
  "version": "0.1.1",
  "description": "React primitives authored with CSS modules for Steez UI.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@steez-ui/icons": "workspace:*",
    "@steez-ui/theme": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/Buttons.module.css": "./dist/styles/Buttons.module.css"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.json && node ../../scripts/copy-static-assets.mjs ."
  },
  "publishConfig": {
    "access": "public"
  }
}
